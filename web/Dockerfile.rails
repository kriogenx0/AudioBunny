FROM ruby:3.3-slim

RUN apt-get update && apt-get install -y \
    build-essential \
    libsqlite3-dev \
    libyaml-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY rails/Gemfile ./
RUN bundle config set without 'development test' \
 && bundle install

COPY rails/ .

RUN mkdir -p storage/presets db tmp/pids tmp/sockets log \
    && chmod +x bin/rails

EXPOSE 3000
